# Hiddenwing — Family Edition · environment variables
# ---------------------------------------------------------------------------
# HOW TO USE:
#   1. Copy this file to ".env.local"   ->   cp .env.example .env.local
#   2. Fill in the real values in .env.local (NEVER commit .env.local)
#   3. This .env.example (with EMPTY values) is safe to commit as documentation.
#
# NOTE: We deliberately use Duffel (not Amadeus — its self-service API is being
# retired in 2026) and Anthropic/Claude (not OpenAI). No Stripe yet — the Family
# Edition takes no payments. See docs/architecture/24-technology-stack-decisions.md
# ---------------------------------------------------------------------------

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Needed in Milestone 1 (database + auth) ---
# Database — Neon serverless Postgres (free tier). https://neon.tech
DATABASE_URL=

# Auth — Clerk (free tier). https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Where Clerk sends users after sign-in/up (defaults shown; usually no need to change)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# --- Needed later (leave empty for now) ---
# Milestone 2 — Flight data (Duffel). https://duffel.com
DUFFEL_ACCESS_TOKEN=

# Milestone 4 — AI layer (Google Gemini, free tier). https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional model override (defaults to gemini-2.5-flash)
GEMINI_MODEL=

# Reserved for a future AI-provider upgrade (Anthropic Claude). Not used yet.
ANTHROPIC_API_KEY=
