// FlightAI — Family Edition · Database schema
// Milestone 1: just enough to prove auth <-> database works.
// Later milestones add PreferenceProfile, Search, TripSolution, etc.
// (see docs/architecture/09-database-design.md for the full Scale-Edition model).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique // links this row to the Clerk user
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Milestone 2: a flight search and a snapshot of the offers it returned.
/// M3 ranks these; M6 re-validates prices against them. A stored price is NEVER
/// bookable — see docs/architecture/adr/0009-offer-snapshot-storage.md
model Search {
  id            String   @id @default(cuid())
  userId        String? // Clerk user id of whoever ran the search
  origin        String
  destination   String
  departureDate String
  returnDate    String?
  adults        Int
  children      Int
  infants       Int
  cabinClass    String
  provider      String
  offerCount    Int
  createdAt     DateTime @default(now())
  offers        Offer[]

  @@index([userId])
  @@index([createdAt])
}

model Offer {
  id              String   @id @default(cuid())
  searchId        String
  search          Search   @relation(fields: [searchId], references: [id], onDelete: Cascade)
  providerOfferId String
  provider        String
  totalAmount     Decimal  @db.Decimal(10, 2)
  currency        String
  owner           String
  cabinClass      String
  stops           Int
  normalized      Json // full normalized offer snapshot (fetchedAt lives inside)
  fetchedAt       DateTime
  createdAt       DateTime @default(now())

  @@index([searchId])
}
